\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Histograms of fitted probabilities of being approved as a cardholder under the LPM, probit, and logit models with the full set of controls. The dashed lines in the LPM panel bound the legitimate probability domain $[0,1]$; about $4.05\%$ of LPM fitted values fall outside this range, while the probit and logit panels are bounded by construction. Source: own calculations using \texttt  {AmEx.dta}.}}{44}{figure.caption.17}\protected@file@percent }
\newlabel{fig:p1_amex_fitted}{{1}{44}{Histograms of fitted probabilities of being approved as a cardholder under the LPM, probit, and logit models with the full set of controls. The dashed lines in the LPM panel bound the legitimate probability domain $[0,1]$; about $4.05\%$ of LPM fitted values fall outside this range, while the probit and logit panels are bounded by construction. Source: own calculations using \texttt {AmEx.dta}}{figure.caption.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Predicted probability of remaining employed in April 2009, conditional on April 2008 full-time employment, as a function of age. LPM, probit, and logit predictions coincide almost everywhere inside the age support. Source: own calculations using \texttt  {employment\_08\_09.dta}.}}{45}{figure.caption.18}\protected@file@percent }
\newlabel{fig:p1_age}{{2}{45}{Predicted probability of remaining employed in April 2009, conditional on April 2008 full-time employment, as a function of age. LPM, probit, and logit predictions coincide almost everywhere inside the age support. Source: own calculations using \texttt {employment\_08\_09.dta}}{figure.caption.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Probit-estimated age profile of employment retention for the Great Recession sample (2008--2009) compared to a normal-times benchmark (2006--2007). The recession lowers the entire curve by roughly $2$ pp and slightly steepens it at the tails. Source: own calculations using \texttt  {employment\_06\_07.dta} and \texttt  {employment\_08\_09.dta}.}}{46}{figure.caption.19}\protected@file@percent }
\newlabel{fig:p1_normal}{{3}{46}{Probit-estimated age profile of employment retention for the Great Recession sample (2008--2009) compared to a normal-times benchmark (2006--2007). The recession lowers the entire curve by roughly $2$ pp and slightly steepens it at the tails. Source: own calculations using \texttt {employment\_06\_07.dta} and \texttt {employment\_08\_09.dta}}{figure.caption.19}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Predicted probability of smoking by education category, holding all other covariates at their sample means. LPM and probit yield indistinguishable predictions. The probability of smoking is monotonically decreasing in education. Source: own calculations using \texttt  {smoking.dta}.}}{47}{figure.caption.20}\protected@file@percent }
\newlabel{fig:p2_educ}{{4}{47}{Predicted probability of smoking by education category, holding all other covariates at their sample means. LPM and probit yield indistinguishable predictions. The probability of smoking is monotonically decreasing in education. Source: own calculations using \texttt {smoking.dta}}{figure.caption.20}{}}
