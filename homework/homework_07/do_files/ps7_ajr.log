. * Helper: write a \newcommand with a 3-decimal formatt
> ed number.
. local cols "ca cb cc cd ce cf cg ch ci"

. foreach c of local cols {
  2.     file write mac "\newcommand{\ajr" "`c'" "bsecon
> d}{" %5.3f (b2_`c') "}" _n
  3.     file write mac "\newcommand{\ajr" "`c'" "seseco
> nd}{" %5.3f (se2_`c') "}" _n
  4.     file write mac "\newcommand{\ajr" "`c'" "bfirst
> }{"   %5.3f (b1_`c') "}" _n
  5.     file write mac "\newcommand{\ajr" "`c'" "sefirs
> t}{"  %5.3f (se1_`c') "}" _n
  6.     file write mac "\newcommand{\ajr" "`c'" "Rsq}{"
>       %5.3f (r2_`c') "}" _n
  7.     file write mac "\newcommand{\ajr" "`c'" "N}{"  
>       %4.0f (N_`c')  "}" _n
  8. }

