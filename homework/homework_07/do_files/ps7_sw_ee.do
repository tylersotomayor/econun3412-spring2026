*==============================================================
* E12.2  Movie attendance and assaults (movies.dta)
*==============================================================
use "data/movies.dta", clear
di _dup(60) "=" _n "E12.2 MOVIES" _n _dup(60) "="
count
scalar n_mov = r(N)

gen ln_assaults = ln(assaults)
gen attend = attend_v + attend_m + attend_n

* (a.i) seasonality in ln_assaults
reg ln_assaults month2-month12 year2-year10, r
test month2 month3 month4 month5 month6 month7 month8 month9 month10 month11 month12
scalar mv_ai_F = r(F)
scalar mv_ai_p = r(p)

* (a.ii) seasonality in total attendance
reg attend month2-month12 year2-year10, r
test month2 month3 month4 month5 month6 month7 month8 month9 month10 month11 month12
scalar mv_aii_F = r(F)
scalar mv_aii_p = r(p)

* (b) OLS of ln_assaults on attend_v attend_m attend_n + rec11 controls (w_* h_*)
reg ln_assaults attend_v attend_m attend_n month2-month12 year2-year10 w_* h_*, r
scalar mv_b_bv = _b[attend_v]
scalar mv_b_sev = _se[attend_v]
scalar mv_b_bm = _b[attend_m]
scalar mv_b_sem = _se[attend_m]
scalar mv_b_bn = _b[attend_n]
scalar mv_b_sen = _se[attend_n]

* Pairwise equality tests (for the SW (b)(ii) question as written)
test attend_v = attend_m
scalar mv_b_pvm = r(p)
test attend_v = attend_n
scalar mv_b_pvn = r(p)

* Joint zero test (rec11 style)
test attend_v attend_m attend_n
scalar mv_b_Fj  = r(F)
scalar mv_b_pj  = r(p)

* (b.iii) scenario via lincom (rec11 style): +6M violent, -2M moderate, -1M nonviolent
lincom 6*attend_v - 2*attend_m - 1*attend_n
scalar mv_b_predict = r(estimate)
scalar mv_b_predSE  = r(se)
scalar mv_b_predLo  = r(lb)
scalar mv_b_predHi  = r(ub)

* (c) IV with pr_attend_v/m/n as instruments (rec11 style: small r)
ivregress 2sls ln_assaults (attend_v attend_m attend_n = pr_attend_v pr_attend_m pr_attend_n) month2-month12 year2-year10 w_* h_*, small r
scalar mv_c_bv = _b[attend_v]
scalar mv_c_sev = _se[attend_v]
scalar mv_c_bm = _b[attend_m]
scalar mv_c_sem = _se[attend_m]
scalar mv_c_bn = _b[attend_n]
scalar mv_c_sen = _se[attend_n]
test attend_v = attend_m
scalar mv_c_pvm = r(p)
test attend_v = attend_n
scalar mv_c_pvn = r(p)
lincom 6*attend_v - 2*attend_m - 1*attend_n
scalar mv_c_predict = r(estimate)
scalar mv_c_predSE  = r(se)
scalar mv_c_predLo  = r(lb)
scalar mv_c_predHi  = r(ub)
* First-stage F for each endogenous regressor
reg attend_v pr_attend_v pr_attend_m pr_attend_n month2-month12 year2-year10 w_* h_*, r
test pr_attend_v pr_attend_m pr_attend_n
scalar mv_c_F_v = r(F)
reg attend_m pr_attend_v pr_attend_m pr_attend_n month2-month12 year2-year10 w_* h_*, r
test pr_attend_v pr_attend_m pr_attend_n
scalar mv_c_F_m = r(F)
reg attend_n pr_attend_v pr_attend_m pr_attend_n month2-month12 year2-year10 w_* h_*, r
test pr_attend_v pr_attend_m pr_attend_n
scalar mv_c_F_n = r(F)

* (d) IV with six surrounding-week instruments (rec11 style)
ivregress 2sls ln_assaults (attend_v attend_m attend_n = attend_v_f attend_m_f attend_n_f attend_v_b attend_m_b attend_n_b) month2-month12 year2-year10 w_* h_*, small r
scalar mv_d_bv = _b[attend_v]
scalar mv_d_sev = _se[attend_v]
scalar mv_d_bm = _b[attend_m]
scalar mv_d_sem = _se[attend_m]
scalar mv_d_bn = _b[attend_n]
scalar mv_d_sen = _se[attend_n]
lincom 6*attend_v - 2*attend_m - 1*attend_n
scalar mv_d_predict = r(estimate)
scalar mv_d_predSE  = r(se)

* (e) J-test overidentification, rec11 style: NR^2 from residual regression
ivregress 2sls ln_assaults (attend_v attend_m attend_n = pr_attend_v pr_attend_m pr_attend_n attend_v_f attend_m_f attend_n_f attend_v_b attend_m_b attend_n_b) month2-month12 year2-year10 w_* h_*, small r
predict e_iv, residuals
reg e_iv pr_attend_v pr_attend_m pr_attend_n attend_v_f attend_m_f attend_n_f attend_v_b attend_m_b attend_n_b, r
scalar mv_e_J   = e(r2) * e(N)
scalar mv_e_Jdf = 6    // 9 instruments - 3 endogenous regressors
scalar mv_e_Jp  = 1 - chi2(mv_e_Jdf, mv_e_J)

file write mac "\newcommand{\movN}{"        %4.0f (n_mov)     "}" _n
