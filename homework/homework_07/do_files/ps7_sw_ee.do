*==============================================================
* E13.1  Race/gender discrimination in callbacks  (names.dta)
*==============================================================
use "data/names.dta", clear
di _dup(60) "=" _n "E13.1 NAMES" _n _dup(60) "="
count
scalar n_names = r(N)

gen black_female = black*female
gen black_high   = black*high

* (a) Raw callback rates by race and diff-in-means 95% CI; cross-check with LPM
sum call_back
scalar nm_overall = r(mean)
sum call_back if black == 0
scalar nm_cb_white = r(mean)
scalar nm_n_white  = r(N)
sum call_back if black == 1
scalar nm_cb_black = r(mean)
scalar nm_n_black  = r(N)
scalar nm_diff    = nm_cb_white - nm_cb_black
scalar nm_se_diff = sqrt(nm_cb_white*(1-nm_cb_white)/nm_n_white ///
                        + nm_cb_black*(1-nm_cb_black)/nm_n_black)
scalar nm_t       = nm_diff / nm_se_diff
scalar nm_ci_lo   = nm_diff - 1.96*nm_se_diff
scalar nm_ci_hi   = nm_diff + 1.96*nm_se_diff

* LPM for callback gap (rec11 style)
reg call_back black, r
scalar nm_LPM_b  = _b[black]
scalar nm_LPM_se = _se[black]

* (b) Interaction regression for gender (rec11 style)
reg call_back black female black_female, r
scalar nm_b_black_b   = _b[black]
scalar nm_b_black_se  = _se[black]
scalar nm_b_female_b  = _b[female]
scalar nm_b_female_se = _se[female]
scalar nm_b_bfem_b    = _b[black_female]
scalar nm_b_bfem_se   = _se[black_female]
test black_female
scalar nm_gen_pint    = r(p)
* Implied black effect for men (black=1, female=0): _b[black]
scalar nm_male_b  = nm_b_black_b
scalar nm_male_se = nm_b_black_se
* Implied black effect for women (female=1): _b[black] + _b[black_female]
scalar nm_fem_b   = nm_b_black_b + nm_b_bfem_b
* Compute SE via lincom
lincom black + black_female
scalar nm_fem_se  = r(se)

* (c) High-low difference pooled and by race (rec11 style)
reg call_back high, r
scalar nm_hilo    = _b[high]
scalar nm_hilo_se = _se[high]
reg call_back black high black_high, r
scalar nm_c_black_b    = _b[black]
scalar nm_c_black_se   = _se[black]
scalar nm_c_high_b     = _b[high]
scalar nm_c_high_se    = _se[high]
scalar nm_c_bhigh_b    = _b[black_high]
scalar nm_c_bhigh_se   = _se[black_high]
test black_high
scalar nm_hilo_race_pint = r(p)
* Implied white high-low = _b[high]; implied black high-low = _b[high] + _b[black_high]
scalar nm_wh_hilo = nm_c_high_b
lincom high + black_high
scalar nm_bl_hilo = r(estimate)
* Cell means (for the SW "what is the callback rate for X?" prose)
sum call_back if high == 1 & black == 0
scalar nm_wh_hi = r(mean)
sum call_back if high == 0 & black == 0
scalar nm_wh_lo = r(mean)
sum call_back if high == 1 & black == 1
scalar nm_bl_hi = r(mean)
sum call_back if high == 0 & black == 1
scalar nm_bl_lo = r(mean)

* (d) Balance regression (supplementary; rec11 did not cover this part)
reg black ofjobs yearsexp honors volunteer military empholes ///
    workinschool email computerskills specialskills, r
test ofjobs yearsexp honors volunteer military empholes ///
    workinschool email computerskills specialskills
scalar nm_rand_F = r(F)
scalar nm_rand_p = r(p)

