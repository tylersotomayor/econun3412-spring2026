*==============================================================
* ps7_sw_ee.do  --  SW Empirical Exercises 12.1, 12.2, 13.1
*                   ECON UN3412 Problem Set 7 (ungraded recitation)
*--------------------------------------------------------------
* This file mirrors the TA's recitation 11 do-file (rec11.do):
*   - ivregress ... , small r  (small-sample SE adjustment)
*   - lincom for the 6/-2/-1 predicted change with delta-method SE
*   - test attend_v attend_m attend_n  (joint zero, as in rec11)
*   - Sargan-Hansen J via NR^2 from residual regression
*   - LPM interaction regressions for Q3(b),(c)
* Supplementary: we also compute disaggregated callback rates and
* a balance F-test for Q3(d), which rec11 did not cover.
*
* Produces output/tables/prob_sw_ee_macros.tex with auto-generated
* \newcommand macros for the writeup.
*==============================================================

clear all
set more off
capture log close
* Resolve the project root portably: allow launch from homework_07/ or do_files/.
capture confirm file "data/fertility.dta"
if _rc {
    capture confirm file "../data/fertility.dta"
    if _rc {
        di as err "Could not find data/fertility.dta. Run from homework_07 or homework_07/do_files."
        exit 601
    }
    cd ..
}
capture mkdir "output"
capture mkdir "output/tables"
log using "do_files/ps7_sw_ee.log", replace text

file open mac using "output/tables/prob_sw_ee_macros.tex", write replace
file write mac "% Auto-generated by ps7_sw_ee.do; do not edit by hand." _n

*==============================================================
* E12.1  Fertility and labor supply  (fertility.dta)
*==============================================================
use "data/fertility.dta", clear
di _dup(60) "=" _n "E12.1 FERTILITY" _n _dup(60) "="
count
scalar n_fert = r(N)

* (a) OLS of weeksm1 on morekids
reg weeksm1 morekids, r
scalar ff_a_b  = _b[morekids]
scalar ff_a_se = _se[morekids]

* (c) First stage: morekids on samesex
reg morekids samesex, r
scalar ff_c_b  = _b[samesex]
scalar ff_c_se = _se[samesex]
test samesex
scalar ff_c_F  = r(F)

* (f) IV: weeksm1 on morekids, instrument = samesex, no controls  (rec11 style)
ivregress 2sls weeksm1 (morekids = samesex), small r
scalar ff_f_b  = _b[morekids]
scalar ff_f_se = _se[morekids]
estat firststage

* (g) IV with exogenous controls agem1 black hispan othrace  (rec11 style)
ivregress 2sls weeksm1 (morekids = samesex) agem1 black hispan othrace, small r
scalar ff_g_b  = _b[morekids]
scalar ff_g_se = _se[morekids]
estat firststage
* First-stage F for samesex with controls (for macro display)
reg morekids samesex agem1 black hispan othrace, r
test samesex
scalar ff_g_F  = r(F)

file write mac "\newcommand{\fertN}{"       %9.0fc (n_fert)  "}" _n
file write mac "\newcommand{\fertOLSb}{"    %7.4f (ff_a_b)   "}" _n
file write mac "\newcommand{\fertOLSse}{"   %7.4f (ff_a_se)  "}" _n
file write mac "\newcommand{\fertFSb}{"     %7.4f (ff_c_b)   "}" _n
file write mac "\newcommand{\fertFSse}{"    %7.4f (ff_c_se)  "}" _n
file write mac "\newcommand{\fertFSF}{"     %6.1f (ff_c_F)   "}" _n
file write mac "\newcommand{\fertIVb}{"     %7.4f (ff_f_b)   "}" _n
file write mac "\newcommand{\fertIVse}{"    %7.4f (ff_f_se)  "}" _n
file write mac "\newcommand{\fertIVctrlb}{"  %7.4f (ff_g_b)  "}" _n
file write mac "\newcommand{\fertIVctrlse}{" %7.4f (ff_g_se) "}" _n
