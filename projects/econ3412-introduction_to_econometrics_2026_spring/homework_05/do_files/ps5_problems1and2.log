     density |   .0266885   .0143494     1.86   0.063    -.0014651     .054842
      avginc |   .0012051   .0072778     0.17   0.869     -.013074    .0154842
         pop |   .0427098   .0031466    13.57   0.000     .0365361    .0488836
      pb1064 |   .0808526   .0199924     4.04   0.000     .0416274    .1200778
